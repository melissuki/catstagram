# Create a project at https://supabase.com then paste values from
# Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Public site URL used in email verification + password-reset redirects
# Local: http://localhost:5173
# Prod:  https://YOUR-VERCEL-APP-URL.vercel.app
VITE_APP_URL=https://YOUR-VERCEL-APP-URL.vercel.app
